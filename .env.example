# iAccessibility Website — environment variables (template)
#
# Copy this file to `.env.local` and fill in real values for local development.
# NEVER commit `.env.local` or any file containing real credentials.
#
# The Neon database connection string is RESTRICTED TO COMMUNITY ACCESS ADMINISTRATORS.
# If you are contributing content, components, or accessibility fixes, you do not
# need a database connection. See CONTRIBUTING.md ("Database changes").

# Neon Postgres connection string (Community Access administrators only)
DATABASE_URL=

# Public site URL (used for canonical links, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=https://iaccessibility.net
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon Auth
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# AWS SES transactional email
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
REVIEW_NOTIFICATION_EMAIL=

# Social auto-posting for moderator-published posts (optional).
# Each network only posts when its credentials are set; otherwise it is a no-op.
MASTODON_API_BASE=https://iaccessibility.social
MASTODON_ACCESS_TOKEN=
X_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# DigitalOcean Spaces / S3-compatible uploads
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=techopolis-storage
DO_SPACES_PREFIX=iAccessibility/podcast
DO_SPACES_PUBLIC_URL=
DO_SPACES_CDN_URL=
