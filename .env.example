# iAccessibility Website — environment variables (template)
#
# Copy this file to `.env.local` and fill in real values for local development.
# NEVER commit `.env.local` or any file containing real credentials.
#
# The Neon database connection string is RESTRICTED TO COMMUNITY LEADERS.
# If you are contributing content, components, or accessibility fixes, you do not
# need a database connection. See CONTRIBUTING.md ("Database changes").

# Neon Postgres connection string (community leaders only)
DATABASE_URL=

# Public site URL (used for canonical links, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=https://iaccessibility.net
